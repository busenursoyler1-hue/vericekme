@model vericekme.Models.UserViewModel

@{
    ViewData["Title"] = "MY-Veri Çekme";
}

<style>
    /* SORGULAMA TIMER (SAĞ ÜST ORTA) */
    #timerBox {
        position: fixed;
        top: 25%;
        right: 20px;
        width: 200px;
        z-index: 999;
        display: none;
    }

    /* KOPYALANDI BİLDİRİM */
    .copy-toast {
        position: fixed;
        bottom: 20px;
        right: 20px;
        background: #28a745;
        color: white;
        padding: 10px 18px;
        border-radius: 8px;
        font-weight: bold;
        z-index: 9999;
        display: none;
        box-shadow: 0 5px 15px rgba(0,0,0,0.2);
    }
</style>

<!-- TIMER BOX -->
<div id="timerBox" class="card shadow border-0 text-center">
    <div class="card-header bg-dark text-white">
        Sorgu Süresi
    </div>
    <div class="card-body">
        <h3 class="text-primary fw-bold" id="timer">00:00</h3>
        <p class="text-muted mb-0">Analiz süresi</p>
    </div>
</div>

<!-- TOAST -->
<div id="toast" class="copy-toast">Kopyalandı</div>

<div class="container mt-5">
    <div class="row justify-content-center">

        <div class="col-md-9">

            <div class="text-center mb-4">
                <h1 class="fw-bold text-primary">MY-Sosyal Medya Analiz Aracı</h1>
                <p class="text-muted">Programı Yapan: <span class="badge bg-dark">M.Yıldız</span></p>
            </div>

            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body p-4 text-center">
                    <form asp-action="Analyze" method="post" onsubmit="startTimer(); showTimerBox();">
                        <div class="input-group mb-2">
                            <input type="text"
                                   name="profileUrl"
                                   class="form-control form-control-lg"
                                   placeholder="Profil URL'sini buraya yapıştırın..."
                                   required
                                   onclick="pasteClipboard(this)">
                            <button type="submit" class="btn btn-primary px-5">Analiz Et</button>
                        </div>
                    </form>
                </div>
            </div>

            <script>
                            async function pasteClipboard(el) {
                                try {
                                    const text = await navigator.clipboard.readText();
                                    el.value = text;
                                } catch (err) {
                                    console.log("Panodan okuma başarısız:", err);
                                }
                            }
            </script>

            <div class="card shadow border-0">
                <div class="card-header bg-primary text-white py-3">
                    <h5 class="mb-0">Profil Sorgu Sonucu</h5>
                </div>

                <div class="card-body p-0">
                    <table class="table table-hover align-middle mb-0">
                        <tbody style="font-size: 1.1rem;">

                            <tr>
                                <th class="ps-4 py-3" width="25%">Profil Adı:</th>
                                <td class="text-primary fw-bold"
                                    id="resName"
                                    onclick="copyText('resName')"
                                    style="cursor:pointer">
                                    @Model?.Name
                                </td>
                            </tr>

                            <tr>
                                <th class="ps-4 py-3">Profil ID:</th>
                                <td class="text-primary fw-bold"
                                    id="resId"
                                    onclick="copyText('resId')"
                                    style="cursor:pointer">
                                    @Model?.Id
                                </td>
                            </tr>

                            <tr>
                                <th class="ps-4 py-3">Profil Uzantısı:</th>
                                <td class="text-primary fw-bold">
                                    @Model?.Website?.TrimEnd('/').Split('/').LastOrDefault()
                                </td>
                            </tr>

                            <tr>
                                <th class="ps-4 py-3">Profil URL:</th>
                                <td>
                                    <a href="@Model?.Website"
                                           id="resUrl"
                                           target="_blank"
                                           class="text-primary fw-bold text-decoration-none"
                                           onclick="copyUrl(event)"
                                           style="cursor:pointer">
                                        @Model?.Website
                                    </a>
                                </td>
                            </tr>

                        </tbody>
                    </table>
                </div>

                <div class="card-footer bg-light text-center py-3">
                    <button class="btn btn-success btn-lg w-100" onclick="copyAllData()">
                        <i class="bi bi-clipboard"></i> Tüm Bilgileri Kopyala
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    let seconds = 0;
    let timerInterval = null;

    function startTimer() {
        seconds = 0;
        if (timerInterval) clearInterval(timerInterval);
        timerInterval = setInterval(updateTimer, 1000);
    }

    function updateTimer() {
        seconds++;

        let min = Math.floor(seconds / 60);
        let sec = seconds % 60;

        document.getElementById("timer").innerText =
            String(min).padStart(2, '0') + ":" +
            String(sec).padStart(2, '0');
    }

    function showTimerBox() {
        document.getElementById("timerBox").style.display = "block";
    }

    // COPY + GREEN TOAST
    function showToast() {
        const toast = document.getElementById("toast");
        toast.style.display = "block";

        setTimeout(() => {
            toast.style.display = "none";
        }, 1200);
    }

    function copyText(id) {
        const text = document.getElementById(id).innerText;
        if (!text) return;
        navigator.clipboard.writeText(text);
        showToast();
    }

    function copyUrl(event) {
        event.preventDefault();
        const url = document.getElementById("resUrl").innerText;
        if (!url) return;
        navigator.clipboard.writeText(url);
        showToast();
    }

    function copyAllData() {
        var name = document.getElementById("resName").innerText;
        var id = document.getElementById("resId").innerText;
        var url = document.getElementById("resUrl").innerText;

        var fullText =
            "Profil Adı: " + name + "\n" +
            "Profil ID'si: " + id + "\n" +
            "Profil URL'si: " + url;

        navigator.clipboard.writeText(fullText);
        showToast();
    }
</script>